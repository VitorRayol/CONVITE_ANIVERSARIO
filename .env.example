# Supabase
NEXT_PUBLIC_SUPABASE_URL=sua_url_do_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_do_supabase

# WhatsApp - Número para receber notificações (com código do país, ex: 5511999999999)
WHATSAPP_NUMBER=5511999999999

# WhatsApp Business API (opcional - para envio automático)
WHATSAPP_API_TOKEN=seu_token_da_api
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id

# Senha do painel administrativo
ADMIN_PASSWORD=sua_senha_admin_segura

# URL do Google Maps do local do evento
NEXT_PUBLIC_MAPS_URL=[maps.google.com](https://maps.google.com/?q=Espaco+Mundo+Magico)

# Data do evento (formato ISO)
NEXT_PUBLIC_EVENT_DATE=2025-08-02T13:00:00
